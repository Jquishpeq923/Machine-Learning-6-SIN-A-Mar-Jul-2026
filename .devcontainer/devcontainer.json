{
    "name": "ML Workshop 2 - Work Enviroment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-toolsai.jupyter",
                "ms-toolsai.jupyter-renders",
                "charliermarsh.ruff",
                "ms-azure.vscode-containers"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/app/.env/bin/python",
                "jupyter.notebookFileRoot": "${workspaceFolder}"
            }
        }
    },
    "postCreateCommand": "echo 'source /app/.env/bin/activate' >> ~/.bashrc"
}
